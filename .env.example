# Copy this file to .env and fill in the values
# cp .env.example .env

# JWT signing secret — must be a long random string (min 32 chars)
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-it-to-a-long-random-string


# Get your free API key from:
# https://aistudio.google.com/app/apikey

# Steps:
# 1 Create or login with Google account
# 2 Click "Get API key"
# 3 Click "Create API key"
# 4 Copy the key and paste below

# Optional — only needed for the chatbot endpoint (/audit-logs/ask)
# The application runs without it, but the chatbot endpoint will return an error.

GEMINI_API_KEY=your_gemini_api_key_here

DEBUG=false