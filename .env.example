# Copy this file to .env and fill in the values
# cp .env.example .env

# JWT signing secret — must be a long random string (min 32 chars)
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-it-to-a-long-random-string

# Get your key from: https://console.anthropic.com
# Optional — only needed for the chatbot endpoint (/audit-logs/ask)
# The app runs fine without it, chatbot endpoint will return an error
ANTHROPIC_API_KEY=sk-ant-...

DEBUG=false